# ─── Database ───────────────────────────────────────────────────────────────
# Neon Postgres connection string
# https://console.neon.tech → project → connection string
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# ─── Auth ────────────────────────────────────────────────────────────────────
# BetterAuth secret — generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=your-secret-here-minimum-32-characters

# Your site's canonical URL (no trailing slash)
BETTER_AUTH_URL=https://alvidervishaj.com

# ─── Admin ────────────────────────────────────────────────────────────────────
# Email address that is granted admin access (server-side gate)
ADMIN_EMAIL=you@example.com

# ─── Email ────────────────────────────────────────────────────────────────────
# Resend API key — https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# ─── Upstash Redis ────────────────────────────────────────────────────────────
# https://console.upstash.com → database → REST API
UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token-here

# ─── Cloudflare R2 ────────────────────────────────────────────────────────────
# https://dash.cloudflare.com → R2 → Manage R2 API tokens
CLOUDFLARE_R2_ACCESS_KEY_ID=your-access-key-id
CLOUDFLARE_R2_SECRET_ACCESS_KEY=your-secret-access-key
CLOUDFLARE_R2_ACCOUNT_ID=your-account-id
CLOUDFLARE_R2_BUCKET_NAME=your-bucket-name

# Public URL for the R2 bucket (enable public access in R2 → bucket → settings)
CLOUDFLARE_R2_PUBLIC_URL=https://pub-xxxx.r2.dev

# ─── Client-side env (must be prefixed with VITE_) ───────────────────────────
# Your site's canonical URL — used for RSS, sitemap, and OG tags
VITE_APP_URL=https://alvidervishaj.com

# ─── Analytics (optional) ─────────────────────────────────────────────────────
# Umami — https://umami.is or self-hosted
# Leave blank to disable analytics
VITE_UMAMI_URL=https://analytics.alvidervishaj.com
VITE_UMAMI_WEBSITE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
